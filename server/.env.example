# port your server will run on
PORT=3000

# mongodb connection uri
MONGO_URI=mongodb://localhost:27017/mydatabase

# Access Token (short-lived)
# Recommended expiry: 15m or 30m for better security
ACCESS_TOKEN_SECRET=your_access_token_secret
ACCESS_TOKEN_EXPIRES_IN=15m

# Refresh Token (long-lived)
# Recommended expiry: 1d or 7d (avoid infinite lifespan for security)
REFRESH_TOKEN_SECRET=your_refresh_token_secret
REFRESH_TOKEN_EXPIRES_IN=7d

# ⚠️ Security Note:
# Do NOT share your secret keys. Leaking them could compromise your entire application.